DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-to-a-long-random-string"
PORT=3001
# Production: https://deploy.yourdomain.com — Dev: http://localhost:3000
CORS_ORIGIN="http://localhost:3000"
# On the server: /opt/orchestrator/scripts
# In development: scripts run against real server resources — keep pointed at server path
SCRIPTS_DIR="../../scripts"

# ── Email notifications (optional) ───────────────────────────────────────────
# Set SMTP_HOST to enable email alerts on deploy failure/success.
# Recipient address is configured in the panel Settings page (notify_email).
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=user@example.com
#SMTP_PASS=yourpassword
#SMTP_FROM="Orchestrator <noreply@example.com>"
