generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  password    String
  role        String     @default("admin") // "admin" | "developer" | "viewer"
  allSitesAccess Boolean @default(false) // non-admin: bypasses per-site SiteUser checks, grants access to all sites incl. future ones
  totpSecret  String?
  totpEnabled Boolean    @default(false)
  createdAt   DateTime   @default(now())
  siteUsers   SiteUser[]
  auditLogs   AuditLog[]

  tasksAssigned     Task[]                  @relation("TaskAssignee")
  tasksCreated      Task[]                  @relation("TaskCreator")
  taskComments      TaskComment[]
  notes             Note[]
  noteShares        NoteShare[]
  calendarEvents    CalendarEvent[]
  calendarAttending CalendarEventAttendee[]
  dashboardPresets  DashboardPreset[]
  accessTokens      PersonalAccessToken[]
  envVersions       EnvVersion[]
  telegramLink      TelegramLink?
}

// Links a panel user to their Telegram account so the bot can act on their
// behalf with their exact role/site permissions. `linkCode` is a one-time,
// short-lived code generated in the panel; once the user sends it to the bot,
// telegramUserId/chatId are filled in and the code is cleared.
model TelegramLink {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramUserId  String?   @unique
  chatId          String?
  username        String?
  linkCode        String?   @unique
  linkCodeExpires DateTime?
  linkedAt        DateTime?
  createdAt       DateTime  @default(now())
}

// Personal Access Token for scripting the panel API (CI, curl). Only a SHA-256
// hash of the token is stored — the plaintext is shown once at creation and can
// never be recovered. Tokens carry the owning user's role (checked the same way
// as a JWT session).
model PersonalAccessToken {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  tokenHash   String    @unique
  tokenPrefix String    // first chars, for display only ("orch_1a2b…")
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

// Per-user monitoring dashboard layout. `name` "__auto__" holds the live
// working layout (auto-saved on every change); any other name is a user-saved
// preset. `config` is a JSON string: an ordered array of { id, width, visible }.
model DashboardPreset {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  config    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

// A managed server the panel can operate. A single self-managed "local" row
// (kind="local") is seeded automatically and represents the host the panel runs
// on — its execution path is the original in-process/local-shell behaviour and
// is never changed. Additional rows (kind="remote") are reached over SSH.
// SSH credentials are encrypted at rest. All existing sites have serverId=null,
// which resolves to the local server, so nothing about them changes.
model Server {
  id            Int      @id @default(autoincrement())
  name          String                          // display label
  kind          String   @default("remote")     // "local" | "remote"
  host          String?                          // hostname/IP (null for local)
  port          Int      @default(22)
  sshUser       String   @default("root")
  sshKey        String?                          // encrypted private key (PEM), remote only
  sshKeyFingerprint String?                      // for display (not the key itself)
  scriptsSynced Boolean  @default(false)         // scripts/ dir copied to remote yet
  status        String   @default("unknown")     // unknown | online | offline
  lastSeenAt    DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sites         Site[]
  metricSamples MetricSample[]
}

model Site {
  id              Int            @id @default(autoincrement())
  name            String
  domain          String         @unique
  // Which server this site lives on. null = the local server (default), so all
  // pre-existing sites keep their exact current local execution path.
  serverId        Int?
  server          Server?        @relation(fields: [serverId], references: [id])
  phpVersion      String         @default("8.2")
  dbName          String?
  dbUser          String?
  sslEnabled      Boolean        @default(false)
  rootPath        String
  status          String         @default("pending")
  repoUrl         String?
  branch          String         @default("main")
  webhookToken    String?        @unique
  gitToken        String?
  preDeploy       String?
  postDeploy      String?
  healthCheck     Boolean        @default(false)
  healthCheckUrl  String?
  // ── Deploy-time PHP tests (all default off → existing sites are unaffected) ──
  runTests        Boolean        @default(false)  // run tests before going live
  testCommand     String         @default("php artisan test")
  testFailureMode String         @default("block") // "block" (abort deploy) | "warn" (continue)
  testTimeout     Int            @default(300)      // seconds
  testUseSqlite   Boolean        @default(true)     // run against isolated in-memory SQLite (safe)
  deployQueued    Boolean        @default(false)
  maintenanceMode Boolean        @default(false)
  uptimeMonitor   Boolean        @default(true)
  statusPageEnabled Boolean      @default(false)
  statusPageToken   String?      @unique
  // ── Per-site nginx security (all default off → existing sites unaffected) ──
  secBasicAuth    Boolean        @default(false)
  secBasicUser    String?
  secBasicHash    String?        // bcrypt hash; htpasswd line = "user:hash"
  secIpMode       String?        // "allow" (allowlist) | "deny" (denylist) | null
  secIpList       String?        // JSON array of IPs/CIDRs
  pinned          Boolean        @default(false)
  disabled        Boolean        @default(false) // serving toggled off via Nginx (distinct from maintenanceMode)
  tags            String         @default("[]")
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deployments     Deployment[]
  uptimeChecks    UptimeCheck[]
  siteUsers       SiteUser[]
  databases       SiteDatabase[]
  tasks           Task[]
  noteEntries     Note[]
  calendarEvents  CalendarEvent[]
  envVersions     EnvVersion[]
  logErrors       LogError[]
  subscription    Subscription?
  invoices        Invoice[]
}

// A grouped application error mined from a site's Laravel log (mini-Sentry).
// Occurrences are collapsed by a fingerprint (exception class + normalized
// message) so the same error counts up rather than flooding the list.
model LogError {
  id             Int      @id @default(autoincrement())
  siteId         Int
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  fingerprint    String
  level          String   // error | critical | emergency | alert | warning
  exceptionClass String?
  message        String
  sample         String?  // the raw header line, for context
  count          Int      @default(1)
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  resolved       Boolean  @default(false)
  ignored        Boolean  @default(false) // muted — the collector stops re-surfacing this group
  aiExplanation  String?  // cached AI explanation (computed once, on demand)
  createdAt      DateTime @default(now())

  @@unique([siteId, fingerprint])
  @@index([siteId, lastSeenAt])
  @@index([resolved, lastSeenAt])
}

// Per-day AI usage counter, for the optional daily call limit / cost control.
model AiUsage {
  id    Int    @id @default(autoincrement())
  date  String @unique // YYYY-MM-DD
  count Int    @default(0)
}

// In-app notification feed (deploy results, threshold alerts, SSL, …). Global
// to the panel — the bell shows the unread count and recent items.
model Notification {
  id        Int      @id @default(autoincrement())
  type      String   // 'deploy' | 'alert' | 'ssl' | 'uptime' | 'system'
  level     String   @default("info") // info | success | warning | critical
  title     String
  body      String?
  meta      String?  // JSON blob (e.g. { siteId, domain })
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
}

// A user-defined threshold on a system metric. The alerts monitor evaluates
// enabled rules on a schedule and raises a Notification (and fans out to the
// configured channels) when the condition holds, respecting a per-rule cooldown.
model AlertRule {
  id              Int       @id @default(autoincrement())
  metric          String    // 'cpu' | 'ram' | 'disk' | 'swap'
  operator        String    @default("gt") // 'gt' | 'lt'
  threshold       Int       // percent (0–100)
  enabled         Boolean   @default(true)
  cooldownMins    Int       @default(30)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
}

// Snapshot of a site's .env each time it's saved from the panel, so edits can
// be diffed and rolled back. Content is encrypted at rest (it holds secrets).
model EnvVersion {
  id          Int      @id @default(autoincrement())
  siteId      Int
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  content     String
  note        String?
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([siteId, createdAt])
}

model SiteUser {
  id        Int      @id @default(autoincrement())
  userId    Int
  siteId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, siteId])
  @@index([siteId])
}

model SiteDatabase {
  id        Int      @id @default(autoincrement())
  siteId    Int
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  dbName    String   @unique
  dbUser    String
  // Plaintext, same trust model as Setting.mysql_root_password and shared/.env.
  // Never returned by GET endpoints — selected out explicitly in db-manage.ts.
  // Empty for isPrimary rows; primary credentials live in shared/.env instead.
  dbPass    String   @default("")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([siteId])
}

model UptimeCheck {
  id          Int      @id @default(autoincrement())
  siteId      Int
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status      String
  responseMs  Int?
  statusCode  Int?
  checkedAt   DateTime @default(now())

  @@index([siteId, checkedAt])
}

// Time-series samples of host resource usage, captured by the metrics monitor.
// Powers the historical CPU / RAM / disk charts on the Monitoring page.
model MetricSample {
  id          Int      @id @default(autoincrement())
  // null = the local server (keeps all historical rows valid without backfill).
  serverId    Int?
  server      Server?  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  cpuPercent  Int
  ramPercent  Int
  diskPercent Int
  checkedAt   DateTime @default(now())

  @@index([checkedAt])
  @@index([serverId, checkedAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  siteId    Int?
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  meta      String?
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Deployment {
  id        Int      @id @default(autoincrement())
  siteId    Int
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  commit    String?
  branch    String   @default("main")
  status    String   @default("pending")
  log       String?
  comment   String?
  testResult String? // null = not run | "passed" | "failed" | "skipped"
  testsPassed    Int?  // parsed from the test runner summary (best-effort)
  testsFailed    Int?
  testsTotal     Int?
  testDurationMs Int?
  createdAt DateTime @default(now())
}

// ── Task Management (Kanban) ─────────────────────────────────────────────────
// Unified link pattern: Task/Note/CalendarEvent all carry an optional siteId
// so any item can be tied to a specific site. CalendarEvent additionally
// carries an optional taskId so a task's due date can surface on the
// calendar without duplicating data.
model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("todo")   // todo | in_progress | review | done
  priority    String   @default("medium") // low | medium | high | urgent
  position    Float    @default(0)        // ordering within a kanban column
  dueDate     DateTime?
  tags        String   @default("[]")     // JSON string array

  siteId      Int?
  site        Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)

  assigneeId  Int?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById Int
  createdBy   User     @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  comments    TaskComment[]
  checklist   TaskChecklistItem[]
  calendarEvents CalendarEvent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([assigneeId])
  @@index([siteId])
  @@index([status])
}

model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
}

model TaskChecklistItem {
  id       Int     @id @default(autoincrement())
  taskId   Int
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text     String
  done     Boolean @default(false)
  position Int     @default(0)

  @@index([taskId])
}

// ── Notes ─────────────────────────────────────────────────────────────────────
model Note {
  id        Int      @id @default(autoincrement())
  title     String
  body      String   @default("") // markdown
  pinned    Boolean  @default(false)
  isPublic  Boolean  @default(false) // visible (read-only) to every panel user
  tags      String   @default("[]") // JSON string array

  ownerId   Int
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  siteId    Int?
  site      Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)

  shares    NoteShare[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([siteId])
}

model NoteShare {
  id      Int     @id @default(autoincrement())
  noteId  Int
  note    Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId  Int
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  canEdit Boolean @default(false)

  @@unique([noteId, userId])
  @@index([userId])
}

// ── Calendar ──────────────────────────────────────────────────────────────────
model CalendarEvent {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  type        String    @default("custom") // custom | reminder | maintenance | task_deadline
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean   @default(false)
  color       String?
  recurrence  String?   // null | daily | weekly | monthly
  reminderMins Int?

  siteId      Int?
  site        Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)

  taskId      Int?
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdById Int
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  attendees   CalendarEventAttendee[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([siteId])
  @@index([startAt])
}

model CalendarEventAttendee {
  id      Int           @id @default(autoincrement())
  eventId Int
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  Int
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════
//  BILLING
//
//  Money is ALWAYS stored as an integer in the currency's minor unit
//  (tetri for GEL, cents for USD/EUR). Never floats — no rounding drift.
//
//  Everything here is additive and inert until `billing_enforcement` is
//  switched on in Settings (default "off"), so existing hosted sites are
//  completely unaffected by simply having these tables present.
// ═══════════════════════════════════════════════════════════════════════════

/// A person/company that pays for one or more sites. Deliberately separate
/// from `User` — a client never needs panel access.
model Client {
  id             Int      @id @default(autoincrement())
  name           String
  email          String?
  phone          String?
  telegramChatId String?
  company        String?
  taxId          String?
  currency       String   @default("GEL")
  locale         String   @default("ka") // "ka" | "en" — dunning message language
  /// Token for the read-only client portal (same pattern as status pages).
  portalToken    String?  @unique
  notes          String?
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions  Subscription[]
  invoices       Invoice[]

  @@index([archived])
}

/// A reusable price + dunning policy. A Subscription may override both.
model Plan {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  /// Minor units (e.g. 3000 = 30.00 GEL)
  amount          Int
  currency        String   @default("GEL")
  interval        String   @default("monthly") // "monthly" | "yearly" | "custom_days"
  intervalDays    Int?     // used when interval = "custom_days"
  /// JSON array of dunning steps; empty string = use the built-in default ladder.
  dunningPolicy   String   @default("")
  gracePeriodDays Int      @default(3)
  autoSuspend     Boolean  @default(true)
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   Subscription[]
}

/// Binds a site to a client at a price, on that client's own billing anchor.
model Subscription {
  id              Int      @id @default(autoincrement())
  /// One active subscription per site.
  siteId          Int      @unique
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  clientId        Int
  /// Restrict: never silently orphan invoices by deleting a client.
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  planId          Int?
  plan            Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)

  /// Snapshot of the price actually charged (may differ from the plan).
  amount          Int
  currency        String   @default("GEL")
  interval        String   @default("monthly")
  intervalDays    Int?
  /// Day of month (1–28) this client is billed on. Each client can differ.
  anchorDay       Int?

  startDate       DateTime @default(now())
  /// When the next invoice should be generated (drives the daily tick).
  nextInvoiceAt   DateTime
  status          String   @default("active") // active | past_due | suspended | cancelled | paused

  /// Current serving-layer enforcement applied to the site.
  enforcementLevel String  @default("none") // none | banner | restrict | suspend | archived
  lastEnforcedAt   DateTime?

  /// Safety valves.
  neverAutoSuspend Boolean @default(false)
  gracePeriodDays  Int     @default(3)
  /// JSON override of the plan/default ladder; empty = inherit.
  dunningPolicy    String  @default("")

  suspendedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices        Invoice[]
  events          BillingEvent[]

  @@index([status])
  @@index([nextInvoiceAt])
  @@index([clientId])
}

/// Immutable once issued: amounts are a snapshot, the number never changes.
model Invoice {
  id             Int      @id @default(autoincrement())
  /// Sequential, human-facing, e.g. "INV-2026-0042".
  number         String   @unique
  clientId       Int
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  siteId         Int?
  site           Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)

  periodStart    DateTime
  periodEnd      DateTime
  issuedAt       DateTime?
  dueDate        DateTime

  /// Minor units. `amountPaid` supports partial payments.
  amount         Int
  amountPaid     Int      @default(0)
  currency       String   @default("GEL")
  status         String   @default("draft") // draft | open | partial | paid | overdue | void

  paidAt         DateTime?
  /// JSON snapshot of line items at issue time.
  lineItems      String   @default("[]")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments       Payment[]
  events         BillingEvent[]

  @@index([status, dueDate])
  @@index([clientId])
  @@index([siteId])
}

/// One received payment. Supports cash today; `reference`/`source`/`externalId`
/// are the hooks a future bank-statement import or payment gateway will use
/// (externalId is unique → idempotent imports, no double-crediting).
model Payment {
  id           Int      @id @default(autoincrement())
  invoiceId    Int
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount       Int      // minor units
  currency     String   @default("GEL")
  method       String   @default("cash")   // cash | bank_transfer | card | other
  source       String   @default("manual") // manual | telegram | bank_import | gateway
  /// Bank reference / statement line id — used to match imported statements.
  reference    String?
  /// Idempotency key for imports & gateways.
  externalId   String?  @unique
  receivedAt   DateTime @default(now())
  /// Panel user who recorded it (plain id: no relation, keeps User untouched).
  recordedById Int?
  note         String?
  createdAt    DateTime @default(now())

  @@index([invoiceId])
  @@index([receivedAt])
}

/// Append-only audit of every dunning / enforcement transition.
model BillingEvent {
  id             Int      @id @default(autoincrement())
  subscriptionId Int
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceId      Int?
  invoice        Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  /// reminder_sent | grace_started | banner | restrict | suspend | restored |
  /// archived | invoice_issued | payment_recorded | dry_run
  type           String
  /// Enforcement level before → after (for the ladder transitions).
  fromLevel      String?
  toLevel        String?
  detail         String?
  /// true when the master switch was in dry_run: nothing was actually applied.
  dryRun         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([subscriptionId, createdAt])
  @@index([type])
}

/// Per-year sequence source for invoice numbers (transactional increment).
model BillingCounter {
  year Int @id
  seq  Int @default(0)
}
