generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  password    String
  role        String     @default("admin") // "admin" | "developer" | "viewer"
  allSitesAccess Boolean @default(false) // non-admin: bypasses per-site SiteUser checks, grants access to all sites incl. future ones
  totpSecret  String?
  totpEnabled Boolean    @default(false)
  createdAt   DateTime   @default(now())
  siteUsers   SiteUser[]
  auditLogs   AuditLog[]

  tasksAssigned     Task[]                  @relation("TaskAssignee")
  tasksCreated      Task[]                  @relation("TaskCreator")
  taskComments      TaskComment[]
  notes             Note[]
  noteShares        NoteShare[]
  calendarEvents    CalendarEvent[]
  calendarAttending CalendarEventAttendee[]
}

model Site {
  id              Int            @id @default(autoincrement())
  name            String
  domain          String         @unique
  phpVersion      String         @default("8.2")
  dbName          String?
  dbUser          String?
  sslEnabled      Boolean        @default(false)
  rootPath        String
  status          String         @default("pending")
  repoUrl         String?
  branch          String         @default("main")
  webhookToken    String?        @unique
  gitToken        String?
  preDeploy       String?
  postDeploy      String?
  healthCheck     Boolean        @default(false)
  healthCheckUrl  String?
  // ── Deploy-time PHP tests (all default off → existing sites are unaffected) ──
  runTests        Boolean        @default(false)  // run tests before going live
  testCommand     String         @default("php artisan test")
  testFailureMode String         @default("block") // "block" (abort deploy) | "warn" (continue)
  testTimeout     Int            @default(300)      // seconds
  testUseSqlite   Boolean        @default(true)     // run against isolated in-memory SQLite (safe)
  deployQueued    Boolean        @default(false)
  maintenanceMode Boolean        @default(false)
  uptimeMonitor   Boolean        @default(true)
  pinned          Boolean        @default(false)
  disabled        Boolean        @default(false) // serving toggled off via Nginx (distinct from maintenanceMode)
  tags            String         @default("[]")
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deployments     Deployment[]
  uptimeChecks    UptimeCheck[]
  siteUsers       SiteUser[]
  databases       SiteDatabase[]
  tasks           Task[]
  noteEntries     Note[]
  calendarEvents  CalendarEvent[]
}

model SiteUser {
  id        Int      @id @default(autoincrement())
  userId    Int
  siteId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, siteId])
  @@index([siteId])
}

model SiteDatabase {
  id        Int      @id @default(autoincrement())
  siteId    Int
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  dbName    String   @unique
  dbUser    String
  // Plaintext, same trust model as Setting.mysql_root_password and shared/.env.
  // Never returned by GET endpoints — selected out explicitly in db-manage.ts.
  // Empty for isPrimary rows; primary credentials live in shared/.env instead.
  dbPass    String   @default("")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([siteId])
}

model UptimeCheck {
  id          Int      @id @default(autoincrement())
  siteId      Int
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status      String
  responseMs  Int?
  statusCode  Int?
  checkedAt   DateTime @default(now())

  @@index([siteId, checkedAt])
}

// Time-series samples of host resource usage, captured by the metrics monitor.
// Powers the historical CPU / RAM / disk charts on the Monitoring page.
model MetricSample {
  id          Int      @id @default(autoincrement())
  cpuPercent  Int
  ramPercent  Int
  diskPercent Int
  checkedAt   DateTime @default(now())

  @@index([checkedAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  siteId    Int?
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  meta      String?
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Deployment {
  id        Int      @id @default(autoincrement())
  siteId    Int
  site      Site     @relation(fields: [siteId], references: [id])
  commit    String?
  branch    String   @default("main")
  status    String   @default("pending")
  log       String?
  comment   String?
  testResult String? // null = not run | "passed" | "failed" | "skipped"
  createdAt DateTime @default(now())
}

// ── Task Management (Kanban) ─────────────────────────────────────────────────
// Unified link pattern: Task/Note/CalendarEvent all carry an optional siteId
// so any item can be tied to a specific site. CalendarEvent additionally
// carries an optional taskId so a task's due date can surface on the
// calendar without duplicating data.
model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("todo")   // todo | in_progress | review | done
  priority    String   @default("medium") // low | medium | high | urgent
  position    Float    @default(0)        // ordering within a kanban column
  dueDate     DateTime?
  tags        String   @default("[]")     // JSON string array

  siteId      Int?
  site        Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)

  assigneeId  Int?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById Int
  createdBy   User     @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  comments    TaskComment[]
  checklist   TaskChecklistItem[]
  calendarEvents CalendarEvent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([assigneeId])
  @@index([siteId])
  @@index([status])
}

model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
}

model TaskChecklistItem {
  id       Int     @id @default(autoincrement())
  taskId   Int
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text     String
  done     Boolean @default(false)
  position Int     @default(0)

  @@index([taskId])
}

// ── Notes ─────────────────────────────────────────────────────────────────────
model Note {
  id        Int      @id @default(autoincrement())
  title     String
  body      String   @default("") // markdown
  pinned    Boolean  @default(false)
  isPublic  Boolean  @default(false) // visible (read-only) to every panel user
  tags      String   @default("[]") // JSON string array

  ownerId   Int
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  siteId    Int?
  site      Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)

  shares    NoteShare[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([siteId])
}

model NoteShare {
  id      Int     @id @default(autoincrement())
  noteId  Int
  note    Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId  Int
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  canEdit Boolean @default(false)

  @@unique([noteId, userId])
  @@index([userId])
}

// ── Calendar ──────────────────────────────────────────────────────────────────
model CalendarEvent {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  type        String    @default("custom") // custom | reminder | maintenance | task_deadline
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean   @default(false)
  color       String?
  recurrence  String?   // null | daily | weekly | monthly
  reminderMins Int?

  siteId      Int?
  site        Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)

  taskId      Int?
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdById Int
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  attendees   CalendarEventAttendee[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([siteId])
  @@index([startAt])
}

model CalendarEventAttendee {
  id      Int           @id @default(autoincrement())
  eventId Int
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  Int
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}
